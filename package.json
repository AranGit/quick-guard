{
  "name": "quick-guard-ui",
  "version": "1.0.3",
  "description": "A lightweight and type-safe Role-Based Access Control (RBAC) library for React and Next.js.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "jest --env=jsdom",
    "test:watch": "jest --watch --env=jsdom",
    "storybook": "storybook dev -p 6006",
    "build": "tsup src/index.ts --format cjs,esm --minify --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts"
  },
  "keywords": [],
  "author": "AranGit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AranGit/quick-guard.git"
  },
  "homepage": "https://github.com/AranGit/quick-guard#readme",
  "bugs": {
    "url": "https://github.com/AranGit/quick-guard/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.19",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
